# Copy to .env and replace every placeholder. Never commit the real .env file.

# Application
PROJECT_NAME=Ecommerce Engine
API_V1_PREFIX=/api/v1
ENVIRONMENT=development
DEBUG=true
# Use explicit origins in staging/production; do not use * with credentials.
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# PostgreSQL (async SQLAlchemy URL)
DATABASE_URL=postgresql+asyncpg://USER:URL_ENCODED_PASSWORD@localhost:5432/ecommerce_engine

# Security: generate a unique 32+ character value, e.g. with `openssl rand -hex 32`.
SECRET_KEY=REPLACE_WITH_A_RANDOM_32_PLUS_CHARACTER_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15

# Redis / Celery / product cache
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
PRODUCT_CACHE_REDIS_URL=redis://localhost:6379/2
PRODUCT_CACHE_TTL_SECONDS=300

# Email / OTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=REPLACE_ME
SMTP_PASSWORD=REPLACE_ME
SMTP_USE_SSL=false
SMTP_USE_STARTTLS=true
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Ecommerce Engine
SMTP_TIMEOUT_SECONDS=10
OTP_LENGTH=6
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_RETENTION_DAYS=7

# Stripe: use sk_test_... locally and sk_live_... only in production.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_CURRENCY=usd
# Each Stripe webhook endpoint has its own whsec_... signing secret.
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# bKash: set BKASH_BASE_URL to the environment issued by bKash.
# Sandbox example: https://tokenized.sandbox.bka.sh/v1.2.0-beta/tokenized
# Production example: https://tokenized.pay.bka.sh/v1.2.0-beta/tokenized
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta/tokenized
BKASH_APP_KEY=REPLACE_ME
BKASH_APP_SECRET=REPLACE_ME
BKASH_USERNAME=REPLACE_ME
BKASH_PASSWORD=REPLACE_ME
# Optional: provide a short-lived token only when your deployment manages token refresh externally.
# BKASH_ID_TOKEN=
