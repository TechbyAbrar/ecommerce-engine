```gitignore
# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.pyo

# -----------------------------------------------------------------------------
# Virtual Environment
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/

# -----------------------------------------------------------------------------
# Environment Variables & Secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Python Packaging
# -----------------------------------------------------------------------------
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# -----------------------------------------------------------------------------
# uv
# -----------------------------------------------------------------------------
.python-version

# Keep uv.lock for reproducible builds
# uv.lock

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.cache/

# -----------------------------------------------------------------------------
# Type Checking
# -----------------------------------------------------------------------------
.mypy_cache/
.pyre/
.pytype/

# -----------------------------------------------------------------------------
# Linting
# -----------------------------------------------------------------------------
.ruff_cache/

# -----------------------------------------------------------------------------
# Jupyter
# -----------------------------------------------------------------------------
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# IDEs
# -----------------------------------------------------------------------------
.vscode/
.idea/

# -----------------------------------------------------------------------------
# Operating System
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
!logs/
logs/*
!logs/.gitkeep
*.log
*.log.*

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
*.pid
*.seed
*.out
*.err

# -----------------------------------------------------------------------------
# FastAPI / Uploads
# -----------------------------------------------------------------------------
uploads/
media/
storage/
tmp/
temp/

# -----------------------------------------------------------------------------
# Static Files
# -----------------------------------------------------------------------------
static/
staticfiles/

# -----------------------------------------------------------------------------
# Alembic
# -----------------------------------------------------------------------------
alembic/versions/*.pyc
alembic/versions/__pycache__/

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# Cache
# -----------------------------------------------------------------------------
.redis/
.cache/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
docker-data/

# -----------------------------------------------------------------------------
# Secrets
# -----------------------------------------------------------------------------
*.pem
*.key
*.crt
*.p12
*.pfx

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.swp
*.swo
*~
```
